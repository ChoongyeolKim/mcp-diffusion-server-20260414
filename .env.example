AZURE_FLUX_ENDPOINT=[YOUR_AZURE_ENDPOINT]
AZURE_FLUX_KEY=[YOUR_AZURE_API_KEY]

# Azure Blob Storage — optional. When set, generated images are uploaded to Blob
# and a public URL is returned instead of raw base64.
AZURE_BLOB_CONNECTION=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=[YOUR_AZURE_STORAGE_CONTAINER]
AZURE_BLOB_DIRECTORY=[YOUR_AZURE_STORAGE_DIRECTORY]

# API key for streamable HTTP transport — optional but recommended for security.
# Clients must send: Authorization: Bearer <key>
MCP_API_KEY=[YOUR_MCP_API_KEY]

# Transport mode: "stdio" (default) | "streamable"
# Set to "streamable" when connecting from Copilot Studio or any HTTP client
MCP_TRANSPORT=stdio

# HTTP port used when MCP_TRANSPORT=streamable (default: 3000)
MCP_PORT=3000
